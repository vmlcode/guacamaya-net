# ── Guacamaya backend — variables de entorno ──────────────────────────────
# Copia este archivo a backend/.env y rellena los valores. backend/.env está
# gitignored: NUNCA comitees secretos reales.

# Puerto HTTP/WS del servidor.
PORT=3000

# Identidad Ed25519 del backend (firma los records oficiales). Si se deja vacío
# se genera un par EFÍMERO en cada arranque y la public key cambia cada reboot.
# Generar un par estable con:
#   bun -e "import * as ed from '@noble/ed25519'; import {bytesToHex} from '@noble/hashes/utils.js'; const p=ed.utils.randomPrivateKey(); console.log('priv',bytesToHex(p)); console.log('pub',bytesToHex(await ed.getPublicKeyAsync(p)))"
BACKEND_PRIVATE_KEY_HEX=
BACKEND_PUBLIC_KEY_HEX=     # se embebe en la app para verificar records oficiales

# ── Supabase (persistencia durable) ───────────────────────────────────────
# Si AMBAS están presentes, channelsRepo/locationsRepo escriben en Supabase
# (tablas channel_records / location_points). Si falta cualquiera, el backend
# cae automáticamente al store en memoria (se pierde al reiniciar) — útil para
# dev, INSERVIBLE para el dashboard offline de alertas.
#
# Dónde obtenerlas: Supabase -> Project Settings -> API
#   SUPABASE_URL               = "Project URL"         (https://<ref>.supabase.co)
#   SUPABASE_SERVICE_ROLE_KEY  = "service_role secret"  (NO la anon key; salta RLS)
# La service-role key es secreta y solo vive en el servidor; nunca en la app.
# Aplicar el esquema una vez: backend/supabase/schema.sql (SQL Editor o supabase db push).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
