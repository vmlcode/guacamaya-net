PORT=3000
NODE_ENV=development

# Ed25519 identity for signing official channel records (stable across restarts).
BACKEND_PRIVATE_KEY_HEX=
BACKEND_PUBLIC_KEY_HEX=

# Security — required in production (NODE_ENV=production).
GUACAMAYA_ADMIN_KEY=          # POST /channels/:id/records (official alerts)
GUACAMAYA_READ_KEY=           # GET /locations (optional; falls back to ADMIN)
GUACAMAYA_WS_KEY=             # WebSocket /ws?token= (optional; falls back to READ)

# CORS — comma-separated origins, or * for dev only.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Ingest limits
MAX_INGEST_BATCH=200
MAX_FRAME_B64_LENGTH=256
MAX_OFFICIAL_PAYLOAD_BYTES=16384

# Supabase (optional — in-memory fallback when unset)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Resolve flow — finder co-signed disarm of an active SOS.
RESOLVE_QUORUM_REQUIRED=2          # M-of-N witnesses required to clear
RESOLVE_QUORUM_TOTAL=3             # max witnesses accepted per target
RESOLVE_GEO_RADIUS_KM=5            # max distance (haversine) from witness to target SOS
RESOLVE_TARGET_MAX_AGE_H=72        # reject resolves against SOS older than this
RESOLVE_COOLDOWN_MIN=15            # pending-clear window before promotion to cleared
RESOLVE_PER_WITNESS_PER_H=5        # leaky-bucket cap per witness deviceId
RESOLVE_EVIDENCE_TTL_MS=300000     # upload-token validity (5 min)
RESOLVE_MAX_IMAGE_BYTES=8388608    # 8 MiB image cap
RESOLVE_EVIDENCE_REQUIRE_AUTH=false  # set true in prod to require read key on /resolve/evidence
EVIDENCE_DIR=.evidence             # dev-only image storage path (relative to backend CWD)
SUPABASE_EVIDENCE_BUCKET=resolve-evidence  # prod-only Supabase Storage bucket
